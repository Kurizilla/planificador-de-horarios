# Copiar a .env en la raíz del repo o en backend/
# Ver docs/setup.md y docs/DEPLOYMENT.md

# --- Base de datos ---
# PostgreSQL (con Docker: docker compose up -d)
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/scheduler

# SQLite (desarrollo sin Docker)
# SQLITE=1
# DATABASE_URL=sqlite:///./scheduler.db

# --- Backend ---
# Storage local para archivos por proyecto/run
STORAGE_ROOT=./data

# JWT: obligatorio en producción (cambiar valor; no commitear)
# JWT_SECRET=change-me-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# User management: set to false to disable public sign-up (users created via seed/script only)
# ALLOW_PUBLIC_REGISTRATION=true

# Whitelist: only these emails can register or be created by admin (comma-separated). Empty = no whitelist.
# USER_WHITELIST=alice@example.com,bob@example.com

# First admin (optional): create with `cd backend && python scripts/seed_user.py`
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=secure-password
# SEED_ADMIN_NAME=Admin

# xAI: necesario para generación de horarios con IA
# XAI_API_KEY=your-xai-api-key
# Opcional: XAI_MODEL, XAI_BASE_URL

# --- Frontend (solo para build de producción) ---
# URL de la API; en dev el frontend usa por defecto http://localhost:8001/api/v1
# VITE_API_URL=https://api.example.com/api/v1
